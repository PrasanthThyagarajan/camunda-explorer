{
  "mcpServers": {
    "camunda": {
      "command": "node",
      "args": ["<PATH_TO_PROJECT>/dist/index.js"],
      "env": {
        "CAMUNDA_BASE_URL": "http://localhost:8080/engine-rest",
        "CAMUNDA_USERNAME": "your-username",
        "CAMUNDA_PASSWORD": "your-password",
        "LOG_LEVEL": "info"
      }
    }
  }
}
